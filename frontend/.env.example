# Khana Bazaar Frontend Environment Variables Template
# Copy this file to .env.local

# Empty = relative URLs. Browser sends /api/v1/* to current origin
# (localhost:3000 or the ngrok host) and Next.js rewrites() proxies
# server-side to http://localhost:8000.
#
# CRITICAL: Must be an explicit empty string. If this line is removed,
# the code fallback "http://localhost:8000" kicks in and breaks mobile
# (phone cannot reach the dev box's localhost). In production, override
# with the absolute backend URL.
NEXT_PUBLIC_API_URL=""

# Google Maps browser key — referrer-restricted in GCP console.
# Used only for rendering the map in <MapPicker>; place lookups go through
# the backend proxy so the server key is never exposed to the browser.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=""

# Web Push applicationServerKey — must equal the backend VAPID_PUBLIC_KEY.
# Empty disables the push opt-in flow.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Server-side backend base URL (absolute). Two consumers:
#   1. RSC / route-handler fetches in lib/api.ts (can't use Next.js rewrites).
#   2. next.config.ts rewrites(): when SET, /api/v1/* is proxied here AND the
#      local /dev-logs log-viewer proxy is dropped (production mode).
# Empty (local dev) = rewrites proxy to http://localhost:8000 + the /dev-logs
# file viewer; RSC falls back to NEXT_PUBLIC_API_URL or http://localhost:8000.
# In production set this to the api Cloud Run *.run.app URL.
INTERNAL_API_URL=""
