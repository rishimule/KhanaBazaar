# /opt/kb/.env on the VM — consumed by the worker container.
# Real values are written at bootstrap from Secret Manager; never commit the real file.
API_IMAGE=asia-south1-docker.pkg.dev/khanabazaar-mvp/kb/api:latest
MEILI_MASTER_KEY=__from_secret_manager__
CLOUDSQL_INSTANCE=khanabazaar-mvp:asia-south1:kb-pg
# Worker connects to Postgres through the local proxy:
DATABASE_URL=postgresql+asyncpg://kbuser:__db_pw__@cloudsql-proxy:5432/khanabazaar
REDIS_URL=redis://redis:6379/0
MEILI_URL=http://meilisearch:7700
JWT_SECRET=__from_secret_manager__
OTP_PEPPER=__from_secret_manager__
ENVIRONMENT=development
EMAIL_PROVIDER=console
SMS_PROVIDER=console
VAPID_PRIVATE_KEY=__from_secret_manager__
VAPID_PUBLIC_KEY=__from_secret_manager__
VAPID_SUBJECT=mailto:sarvakadev@gmail.com
