# /opt/kb/.env on the VM — consumed by the worker container AND by compose
# for ${...} interpolation (compose auto-loads .env from the project dir).
# Real values are written at bootstrap from Secret Manager; never commit the real file.
API_IMAGE=asia-south1-docker.pkg.dev/khanabazaar-mvp/kb/api:latest
VM_INTERNAL_IP=10.10.0.2            # this VM's internal IP (bind redis/meili here)
MEILI_MASTER_KEY=__from_secret_manager__
REDIS_PASSWORD=__from_secret_manager__
CLOUDSQL_INSTANCE=khanabazaar-mvp:asia-south1:kb-pg
# Worker connects to Postgres through the local proxy, redis over the Docker net:
DATABASE_URL=postgresql+asyncpg://kbuser:__db_pw__@cloudsql-proxy:5432/khanabazaar
REDIS_URL=redis://:__redis_pw__@redis:6379/0
MEILI_URL=http://meilisearch:7700
JWT_SECRET=__from_secret_manager__
OTP_PEPPER=__from_secret_manager__
# Displayed brand name in worker-sent emails/SMS (order updates, delivery OTP).
# Keep in sync with the api COMPANY_NAME + web NEXT_PUBLIC_COMPANY_NAME.
COMPANY_NAME=Sarvaka
# Public web origin used to build clickable links in worker-sent comms
# (order/referral emails + referral SMS). MUST be the public HTTPS URL in
# prod; keep in sync with the api EMAIL_FRONTEND_BASE_URL. No trailing slash.
EMAIL_FRONTEND_BASE_URL=https://khanabazaar.rishimule.dev
ENVIRONMENT=development
EMAIL_PROVIDER=console
SMS_PROVIDER=console
VAPID_PRIVATE_KEY=__from_secret_manager__
VAPID_PUBLIC_KEY=__from_secret_manager__
VAPID_SUBJECT=mailto:sarvakadev@gmail.com
