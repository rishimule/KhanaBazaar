# Khana Bazaar Backend Environment Variables Template
# Copy this file to .env and replace the values with your actual configuration.

# PROJECT_NAME (OpenAPI title) derives from COMPANY_NAME as "<COMPANY_NAME> API"
# when left unset. Uncomment to override.
# PROJECT_NAME="Khana Bazaar API"

# Displayed brand name. Falls back to "Khanabazaar". EMAIL_BRAND_NAME and the
# OpenAPI PROJECT_NAME derive from this when left unset.
COMPANY_NAME="Khanabazaar"

ENVIRONMENT="development"

# PostgreSQL Database
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/khanabazaar"

# Redis Broker/Cache
REDIS_URL="redis://localhost:6379/0"

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="change-me-use-secrets-token-hex-32"
JWT_EXPIRES_HOURS=24

# Access token (short-lived) + rotating refresh sessions ("keep me signed in").
# JWT_EXPIRES_HOURS above is retired for the access token; its 24h value now
# lives in SESSION_UNTRUSTED_TTL_HOURS. See
# docs/superpowers/specs/2026-07-17-trusted-device-long-term-signin-design.md
ACCESS_TOKEN_TTL_MINUTES=15
SESSION_UNTRUSTED_TTL_HOURS=24
SESSION_CUSTOMER_IDLE_DAYS=30
SESSION_CUSTOMER_MAX_DAYS=180
SESSION_SELLER_IDLE_DAYS=14
SESSION_SELLER_MAX_DAYS=90
SESSION_ADMIN_IDLE_DAYS=7
SESSION_ADMIN_MAX_DAYS=30
REFRESH_TOKEN_REUSE_GRACE_SECONDS=30
SESSION_REUSE_HISTORY_SIZE=5

# OTP — generate with: python -c "import secrets; print(secrets.token_hex(16))"
OTP_PEPPER="change-me-use-secrets-token-hex-16"
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN=60
OTP_MAX_PER_HOUR=5

# Email: "console" (prints codes to stdout) or "resend" (production)
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# --- SMTP (temporary Gmail sender for LOCAL DEV only) ---
# Set EMAIL_PROVIDER="smtp+console" to deliver real email via Gmail AND capture
# every message to /dev-emails. Use "smtp" for send-only (no dev-mailbox row).
# Gmail requires 2-Step Verification + a 16-char App Password (NOT your account
# password): https://myaccount.google.com/apppasswords
# SMTP_FROM_EMAIL MUST equal SMTP_USERNAME (or a verified "Send mail as" alias),
# otherwise Gmail silently rewrites the From header.
# Consumer Gmail caps at ~500 recipients/day (Workspace ~2000).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_USE_TLS="false"
SMTP_TIMEOUT="10"

# Destination inbox for /customers/me/support messages.
SUPPORT_EMAIL="mailto:support@khanabazaar.dev"
# Reply-to header on customer-facing emails. Empty = falls back to SUPPORT_EMAIL.
EMAIL_REPLY_TO=""
# Brand name shown in email subjects/templates.
EMAIL_BRAND_NAME="Khana Bazaar"
# Public web origin used to build ALL clickable links in comms (email templates +
# referral SMS, and future referral-over-WhatsApp). Local dev = localhost:3000; in
# prod set to the public HTTPS URL (no trailing slash). Set in BOTH the api and VM worker.
EMAIL_FRONTEND_BASE_URL="http://localhost:3000"

# SMS: "console" (logs codes to stdout) or "twilio" (production)
SMS_PROVIDER="console"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# WhatsApp: "none" (disabled) | "console" (mock → dev_whatsapp / /dev-whatsapp) |
# "twilio". Reuses TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN; TWILIO_WHATSAPP_FROM is
# the "whatsapp:+..." sender (sandbox or approved). Use "console" in dev.
WHATSAPP_PROVIDER="none"
TWILIO_WHATSAPP_FROM=""

# CORS — comma-separated list of allowed frontend origins
FRONTEND_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Geo / Google Maps Platform — server key is IP-restricted in GCP console;
# browser key is HTTP-referrer-restricted and exposed to the frontend.
GOOGLE_MAPS_SERVER_API_KEY=""
GOOGLE_MAPS_BROWSER_API_KEY=""
GEO_RATE_LIMIT_PER_MIN=30
GEO_AUTOCOMPLETE_CACHE_TTL_SECONDS=60
GEO_REVERSE_CACHE_TTL_SECONDS=86400

# Meilisearch
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="dev-master-key-change-me"

# Search rate limits + caches (per IP per minute / TTL seconds)
SEARCH_RATE_LIMIT_SUGGEST_PER_MIN=60
SEARCH_RATE_LIMIT_PRODUCTS_PER_MIN=30
SEARCH_RATE_LIMIT_BROWSE_PER_MIN=60
SEARCH_SUGGEST_CACHE_TTL_SECONDS=60
SEARCH_SERVICEABLE_GRID_TTL_SECONDS=60
SEARCH_BROWSE_CACHE_TTL_SECONDS=60

# Web Push (VAPID) — push is disabled/no-op when VAPID_PRIVATE_KEY is empty.
# Keygen: see docs/development_guide.md §12.
# VAPID_PRIVATE_KEY is the RAW base64url EC private key (~43 chars), NOT a
# PKCS8 PEM — pywebpush base64url-decodes it to the 32-byte scalar.
VAPID_PRIVATE_KEY=""
# base64url uncompressed EC point; the browser's applicationServerKey.
# Must equal the frontend NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=""
# Must be a real deliverable contact (real mailto: or https:) — Apple rejects
# placeholder/.example domains with 403 BadJwtToken.
VAPID_SUBJECT="mailto:support@khanabazaar.dev"
